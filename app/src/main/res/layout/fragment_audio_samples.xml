<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical">

	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:background="@color/primary_translucent"
		android:orientation="vertical"
		android:padding="12dp">

		<TextView
			style="@style/ListItem"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:text="@string/audio_sample_folder" />

		<TextView
			style="@style/ListItemSecondary"
			android:id="@+id/audio_sample_folder_summary"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="4dp"
			android:text="@string/audio_sample_no_folder" />

		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="8dp"
			android:orientation="horizontal">

			<Button
				android:id="@+id/choose_audio_sample_folder"
				style="@style/BarButton"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="@string/audio_sample_choose_folder" />

			<Button
				android:id="@+id/clear_audio_sample_folder"
				style="@style/BarButton"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginStart="8dp"
				android:text="@string/audio_sample_clear_folder"
				android:visibility="gone" />
		</LinearLayout>

		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="10dp"
			android:gravity="center_vertical"
			android:orientation="horizontal">

			<Button
				android:id="@+id/audio_sample_up"
				style="@style/BarButton"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="@string/audio_sample_up"
				android:visibility="gone" />

			<LinearLayout
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_marginStart="8dp"
				android:layout_weight="1"
				android:orientation="vertical">

				<TextView
					style="@style/ListItemSecondary"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:text="@string/audio_sample_current_path" />

				<TextView
					style="@style/ListItem"
					android:id="@+id/audio_sample_current_path"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginTop="2dp"
					android:text="@string/audio_sample_root" />
			</LinearLayout>

			<ProgressBar
				android:id="@+id/audio_samples_progress"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginStart="8dp"
				android:visibility="gone" />
		</LinearLayout>
	</LinearLayout>

	<FrameLayout
		android:layout_width="match_parent"
		android:layout_height="0dp"
		android:layout_weight="1">

		<ListView
			android:id="@+id/audio_samples"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:choiceMode="singleChoice"
			android:divider="?attr/colorSurfaceContainerHigh"
			android:dividerHeight="1px" />

		<TextView
			style="@style/ListItemSecondary"
			android:id="@+id/audio_samples_empty"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_gravity="center"
			android:gravity="center"
			android:padding="24dp"
			android:text="@string/audio_sample_loading" />
	</FrameLayout>
</LinearLayout>
