<merge xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto">
	<!-- ShaderView as the background -->
	<de.markusfisch.android.shadereditor.widget.ShaderView
		android:id="@+id/preview"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:fitsSystemWindows="false" />

	<!-- CoordinatorLayout for managing the toolbar, drawer, and content -->
	<androidx.coordinatorlayout.widget.CoordinatorLayout
		android:id="@+id/main_coordinator"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:background="@android:color/transparent">

		<!-- LinearLayout to manage vertical space -->
		<LinearLayout
			android:id="@+id/main_layout"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:background="@android:color/transparent"
			android:orientation="vertical">

			<include layout="@layout/toolbar_main" />

			<HorizontalScrollView
				android:id="@+id/editor_controls_container"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:background="@color/primary_translucent"
				android:fillViewport="true"
				android:overScrollMode="never"
				android:paddingStart="8dp"
				android:paddingTop="4dp"
				android:paddingEnd="8dp"
				android:paddingBottom="4dp">

				<LinearLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:gravity="center_vertical"
					android:orientation="horizontal">

					<FrameLayout
						android:layout_width="44dp"
						android:layout_height="44dp"
						android:layout_marginEnd="4dp">

						<Button
							android:id="@+id/compile_shader"
							style="@style/IconButton"
							android:layout_width="match_parent"
							android:layout_height="match_parent"
							android:contentDescription="@string/compile_shader"
							app:icon="@drawable/ic_compile"
							app:iconSize="22dp" />

						<com.google.android.material.progressindicator.CircularProgressIndicator
							android:id="@+id/compile_progress"
							android:layout_width="18dp"
							android:layout_height="18dp"
							android:layout_gravity="center"
							android:indeterminate="true"
							android:visibility="gone"
							app:indicatorColor="@android:color/white"
							app:indicatorSize="18dp"
							app:indicatorInset="0dp"
							app:trackThickness="2dp" />
					</FrameLayout>

					<Button
						android:id="@+id/reset_time"
						style="@style/IconButton"
						android:layout_width="44dp"
						android:layout_height="44dp"
						android:layout_marginEnd="4dp"
						android:contentDescription="@string/reset_time"
						app:icon="@drawable/ic_rotate_right"
						app:iconSize="22dp" />

					<Space
						android:layout_width="0dp"
						android:layout_height="1dp"
						android:layout_weight="1" />

					<LinearLayout
						android:id="@+id/audio_bpm_container"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_marginStart="4dp"
						android:gravity="center_vertical"
						android:orientation="horizontal"
						android:visibility="gone">

						<TextView
							android:id="@+id/audio_bpm_label"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:layout_marginEnd="6dp"
							android:includeFontPadding="false"
							android:maxLines="1"
							android:singleLine="true"
							android:text="@string/audio_bpm"
							android:textColor="@android:color/white"
							android:textSize="12sp" />

						<EditText
							android:id="@+id/audio_bpm_input"
							android:layout_width="64dp"
							android:layout_height="40dp"
							android:backgroundTint="#55FFFFFF"
							android:ems="4"
							android:gravity="center"
							android:hint="@string/audio_bpm_hint"
							android:importantForAutofill="no"
							android:inputType="numberDecimal"
							android:maxLines="1"
							android:singleLine="true"
							android:textColor="@android:color/white"
							android:textColorHint="#80FFFFFF" />
					</LinearLayout>
				</LinearLayout>
			</HorizontalScrollView>

			<FrameLayout
				android:id="@+id/content_stack"
				android:layout_width="match_parent"
				android:layout_height="0dp"
				android:layout_weight="1">

				<!-- DrawerLayout with main content -->
				<de.markusfisch.android.shadereditor.widget.TouchThruDrawerLayout
					android:id="@+id/drawer_layout"
					android:layout_width="match_parent"
					android:layout_height="match_parent">

					<!-- Content Frame -->
					<androidx.coordinatorlayout.widget.CoordinatorLayout
						android:id="@+id/content_frame"
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:background="@android:color/transparent">

					</androidx.coordinatorlayout.widget.CoordinatorLayout>

					<!-- Navigation Drawer -->
					<include layout="@layout/drawer" />

				</de.markusfisch.android.shadereditor.widget.TouchThruDrawerLayout>

				<LinearLayout
					android:id="@+id/audio_faders_container"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_gravity="bottom"
					android:background="@color/primary_translucent"
					android:orientation="vertical"
					android:paddingStart="4dp"
					android:paddingTop="6dp"
					android:paddingEnd="4dp"
					android:paddingBottom="6dp"
					android:visibility="gone">

					<LinearLayout
						android:id="@+id/audio_faders_track"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:baselineAligned="false"
						android:gravity="center_horizontal"
						android:orientation="horizontal" />
				</LinearLayout>
			</FrameLayout>

			<!-- Extra keys row at the bottom -->
			<include
				layout="@layout/extra_keys"
				android:layout_width="match_parent"
				android:layout_height="wrap_content" />

		</LinearLayout>

		<!-- Nav bar background for SDK35+ -->
		<include layout="@layout/navbar"/>

	</androidx.coordinatorlayout.widget.CoordinatorLayout>
</merge>
